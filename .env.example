# Supabase bağlantısı (opsiyonel — boş bırakılırsa uygulama yerleşik veriyi kullanır)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Senkron scripti (scripts/sync.mjs) için — yalnızca SUNUCUDA kullanılır.
# ⚠️ service_role key RLS'i BYPASS eder (tam yetki). VITE_ öneki YOK, asla istemciye/commit'e koyma!
# Supabase paneli → Settings → API → "service_role" anahtarı.
SUPABASE_SERVICE_ROLE_KEY=

# Eğlenceli AI yorumu (opsiyonel). Boş bırakılırsa şablon yorum gösterilir.
# Ücretsiz Gemini anahtarı: https://aistudio.google.com/apikey
# ⚠️ VITE_ öneki YOK — bu anahtar sadece sunucuda (dev API / Edge Function) kullanılır,
#    tarayıcıya asla gönderilmez.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
